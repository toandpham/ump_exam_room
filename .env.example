# ============================================================
# Exam System — environment configuration
# Copy to .env and adjust. Do NOT commit .env.
# ============================================================

# --- Runtime ---
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_USER=exam
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=exam_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async SQLAlchemy URL (asyncpg). Must match the values above.
DATABASE_URL=postgresql+asyncpg://exam:change_me_postgres@postgres:5432/exam_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
# Generate a strong secret, e.g.: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
BCRYPT_ROUNDS=12

# --- Encryption (at-rest exam payload) ---
PBKDF2_ITERATIONS=600000

# --- Uploads ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20

# --- Rate limiting ---
ADMIN_LOGIN_RATE=10/2minutes    # admin login attempts per IP
EXAM_LOGIN_RATE=10/2minutes      # candidate CCCD login attempts per IP

# --- CORS (dev) ---
CORS_ORIGINS=http://localhost,http://exam-server.local

# --- Frontend (Vite, build-time) ---
# Same-origin via Caddy, so relative paths. Override only if needed.
VITE_API_BASE=/api
VITE_WS_BASE=/ws

# --- Safe Exam Browser (tuỳ chọn, MẶC ĐỊNH TẮT) ---
# Hệ thống hiện dùng phần mềm thi riêng (UMP ExamKiosk) để khoá máy, KHÔNG dùng SEB.
# Để TẮT (khuyến nghị) — thí sinh vào bằng kiosk/trình duyệt bình thường:
SEB_ENFORCE=false
# Chỉ đặt =true nếu bạn CÓ Safe Exam Browser và muốn bắt buộc dùng nó. Khi =true mà
# máy thi không phải SEB thì thí sinh sẽ thấy màn "Cần Safe Exam Browser".
SEB_START_URL=http://exam-server.local/thisinh/
SEB_CONFIG_KEY=

# ⚠️ BẮT BUỘC ĐIỀN — Khoá giải mã đề thi (chuỗi base64, nhà cung cấp cấp).
# ĐỂ TRỐNG = KHÔNG NẠP ĐƯỢC ĐỀ (trang Nạp đề sẽ báo lỗi "chưa cấu hình QTI_SECRET").
# Khoá là bí mật, KHÔNG có trong mã nguồn công khai — xin nhà cung cấp rồi dán vào
# file .env (KHÔNG phải file này). Ví dụ:  QTI_SECRET=xxxxxxxxxxxxxxxxxxxx=
QTI_SECRET=
