# ============================================================
# Exam System — environment configuration
# Copy to .env and adjust. Do NOT commit .env.
# ============================================================

# --- Runtime ---
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_USER=exam
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=exam_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async SQLAlchemy URL (asyncpg). Must match the values above.
DATABASE_URL=postgresql+asyncpg://exam:change_me_postgres@postgres:5432/exam_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
# Generate a strong secret, e.g.: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
BCRYPT_ROUNDS=12

# --- Encryption (at-rest exam payload) ---
PBKDF2_ITERATIONS=600000

# --- Uploads ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20

# --- Rate limiting ---
ADMIN_LOGIN_RATE=10/2minutes    # admin login attempts per IP
EXAM_LOGIN_RATE=10/2minutes      # candidate CCCD login attempts per IP

# --- CORS (dev) ---
CORS_ORIGINS=http://localhost,http://exam-server.local

# --- Frontend (Vite, build-time) ---
# Same-origin via Caddy, so relative paths. Override only if needed.
VITE_API_BASE=/api
VITE_WS_BASE=/ws

# --- Safe Exam Browser (AD-56/57/59) ---
# SEB_ENFORCE MUST stay true in production (every candidate must use SEB).
# SEB_START_URL uses the mDNS hostname (NOT an IP) so one universal .seb works no
# matter what IP the server gets — set the Mac's name once: scutil --set
# LocalHostName exam-server  (then exam-server.local resolves on the LAN).
SEB_START_URL=http://exam-server.local/thisinh/
SEB_ENFORCE=true
# SEB_CONFIG_KEY empty (default) = PRESENCE mode: any request from SEB is accepted,
# a plain browser is blocked. This is universal/IP-independent (AD-59). For strict
# per-.seb cryptographic binding, paste the Config Key shown by the SEB Config Tool.
SEB_CONFIG_KEY=

# Secret giải mã đề .qenc (base64 32 byte) — MẶC ĐỊNH ĐỂ TRỐNG: dùng secret nhúng
# sẵn khớp tool "Mã hoá đề thi" (qti-crypter). Chỉ đặt khi cần rotate khẩn cấp
# mà không rebuild (phải build lại tool với secret mới tương ứng).
QTI_SECRET=
